# ============================================================
# thousandoaksinjury-automation — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to GitHub.
# ============================================================

# Google Sheets
# Found in the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# HeyGen
# Settings → API Keys in your HeyGen dashboard
HEYGEN_API_KEY=your_heygen_api_key_here

# HeyGen Avatar
# Avatars page → click avatar → copy ID from URL or avatar details
HEYGEN_AVATAR_ID=your_avatar_id_here

# HeyGen Voice
# Voice Library → select voice → copy voice_id
HEYGEN_VOICE_ID=your_voice_id_here

# GitHub (for future website deployment automation)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=thousandoaksinjury/thousandoaksinjury-automation

# YouTube (Phase 2 — leave blank until ready)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
